# Sample Ledger env file. Replace placeholders before use.
# Docker volume maps to /srv/data inside the container.
DATABASE_URL=sqlite:///srv/data/ledger.db

# Bind on all interfaces in the container.
GRPC_LISTEN_ADDR=0.0.0.0:50051

# Per-tenant secret keys for Bearer token authentication.
# Keep these aligned with configs/config.ledger.yml and the client env files.
POODLESCANNER_TENANT_SECRET=REPLACE_ME
HECATE_TENANT_SECRET=REPLACE_ME
NAMESIGNAL_TENANT_SECRET=REPLACE_ME
