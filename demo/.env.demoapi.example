# Copy to .env.demoapi and align values with the TAuth environment
DEMOAPI_LISTEN_ADDR=:9090
DEMOAPI_LEDGER_ADDR=ledger:50051
DEMOAPI_LEDGER_INSECURE=true
DEMOAPI_LEDGER_TIMEOUT=3s
DEMOAPI_DEFAULT_TENANT_ID=default
DEMOAPI_DEFAULT_LEDGER_ID=default
DEMOAPI_ALLOWED_ORIGINS=https://localhost:4443,https://127.0.0.1:4443,https://computercat.tyemirov.net:4443
DEMOAPI_JWT_SIGNING_KEY=replace-with-tauth-signing-key
DEMOAPI_JWT_ISSUER=tauth
DEMOAPI_JWT_COOKIE_NAME=app_session
DEMOAPI_TAUTH_BASE_URL=http://tauth:8080
